+private static List<ExpenseSplit> CalculateSharesSplit(AddExpenseRequest request, Guid expenseId)
+{
+    var totalShares = request.Splits.Sum(s => s.Shares!.Value);
+    var splits = new List<ExpenseSplit>(request.Splits.Count);
+    long assignedTotal = 0;
+
+    for (int i = 0; i < request.Splits.Count; i++)
+    {
+        var split = request.Splits[i];
+        long amount;
+
+        if (i == request.Splits.Count - 1)
+        {
+            // Last participant gets the remainder to ensure sum equals total
+            amount = request.AmountMinor - assignedTotal;
+        }
+        else
+        {
+            amount = (split.Shares!.Value * request.AmountMinor) / totalShares;
+            assignedTotal += amount;
+        }
+
+        splits.Add(new ExpenseSplit
+        {
+            ExpenseId = expenseId,
+            UserId = split.UserId,
+            AmountMinor = amount,
+            Shares = split.Shares,
+        });
+    }
+
+    return splits;
+}
+
