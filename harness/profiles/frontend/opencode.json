          "tools": true,
          "reasoning": true,
          "options": {
            "max_tokens": 32768
          }
        }
      }
    }
  },
  "model": "heapzilla/vllm-qwen3-6-27b-fp8",
  "small_model": "heapzilla/vllm-qwen3-6-27b-fp8",
  "instructions": [
