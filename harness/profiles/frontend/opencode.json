{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "heapzilla": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Heapzilla vLLM",
      "options": {
        "baseURL": "http://localhost:3301/v1",
        "apiKey": "{env:HEAPZILLA_API_KEY}"
      },
      "models": {
        "vllm-qwen3-6-27b-fp8": {
          "name": "Qwen3.6-27B-FP8 (local)",
          "tools": true,
          "reasoning": true,
          "options": {
            "max_tokens": 32768,
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0,
            "presence_penalty": 0,
            "repetition_penalty": 1
          }
        },
        "vllm-qwen3.6-35b-a3b": {
          "name": "Qwen3.6-35B-A3B (local)",
          "tools": true,
          "reasoning": true,
          "options": {
            "max_tokens": 32768,
            "temperature": 0.2,
            "top_p": 0.9
          }
        },
        "vllm-gemma-4-31b-fp8": {
          "name": "Gemma-4-31B-FP8 (local)",
          "tools": true,
          "reasoning": true,
          "options": {
            "max_tokens": 32768,
            "temperature": 0.2,
            "top_p": 0.9
