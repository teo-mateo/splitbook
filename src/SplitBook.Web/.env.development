# Dev only. Vite loads this in mode 'development' (the dev server), NOT in
# mode 'test' (vitest), so the test suite keeps its absolute http://localhost:5000
# base that the MSW handlers expect. In dev the app calls a relative /api base
# which vite.config.ts proxies to the real backend → same-origin, no CORS.
VITE_API_URL=/api
